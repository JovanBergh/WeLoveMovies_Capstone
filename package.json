{
  "name": "project-movie-back-end",
  "version": "1.0.0",
  "description": "zid-be-project-movie-01-qualified",
  "main": "src/app.js",
  "scripts": {
    "docker:build": "docker image build . -t thinkful-ed/zid-be-project-movie-01-qualified",
    "docker:run": "docker run --rm -it -p 5001:5001 thinkful-ed/zid-be-project-movie-01-qualified",
    "docker:stop": "docker stop $(docker ps -q)",
    "docker:test": "docker run -t  thinkful-ed/zid-be-project-movie-01-qualified npm test",
    "knex": "knex",
    "migrate": "knex migrate:latest",
    "reset": "npm run rollback && npm run migrate && npm run seed",
    "rollback": "knex migrate:rollback",
    "seed": "knex seed:run",
    "start": "node src/server.js",
    "start:dev": "nodemon src/server.js",
    "start:solution": "docker-compose up --build",
    "test": "jest",
    "test:solution": "docker-compose build && docker-compose run --rm api npm test && docker-compose down"
  },
  "keywords": [],
  "author": "Jovan Bergh",
  "license": "ISC",
  "dependencies": {
    "cacache": "^19.0.1",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^8.2.0",
    "express": "^4.17.1",
    "knex": "^3.1.0",
    "mongoose": "^9.3.1",
    "morgan": "^1.10.0",
    "pg": "^8.4.2",
    "pino-http": "^11.0.0",
    "sqlite3": "^6.0.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "supertest": "^6.1.3"
  },
  "directories": {
    "doc": "docs",
    "test": "test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JovanBergh/WeLoveMovies_Capstone.git"
  },
  "bugs": {
    "url": "https://github.com/JovanBergh/WeLoveMovies_Capstone/issues"
  },
  "homepage": "https://github.com/JovanBergh/WeLoveMovies_Capstone#readme"
}
